<h1>{{title}}</h1>
{{#if conocido}}
    <p>Buenas buenas {{nombre}} <a href="/salir">Salir</a></p>
{{/if}}

{{#unless conocido}}
    <p> No te conozco! </p>
    <form action="/ingresar" method="post">
        <input type="text" name="nombre" placeholder="Ingresa tu nombre"><button type="submit">Ingresar</button>
        
    </form>
{{/unless}}